# BetterStack API Token (required)
# Get it from: https://uptime.betterstack.com/team/settings/api-tokens
BETTERSTACK_API_TOKEN=your_betterstack_api_token_here

# Authentication credentials (required for production)
AUTH_USERNAME=admin
AUTH_PASSWORD=your_secure_password_here

# Session secret (required for production - use a random string)
SESSION_SECRET=your_random_session_secret_here

# Server port (optional, default: 3000)
PORT=3000

# Set to 'production' when deploying
NODE_ENV=production
